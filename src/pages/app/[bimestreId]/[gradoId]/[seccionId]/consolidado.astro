---
import Layout from "../../../../../layouts/Layout.astro";
import ConsolidadoTabs from "../../../../../components/svelte/ConsolidadoTabs.svelte";
import { query } from "../../../../../lib/db";
import { getCurriculoPorNombre } from "../../../../../lib/curriculo/index";
import type {
  Bimestre,
  Grado,
  Seccion,
  Alumno,
  Sesion,
  SesionCriterio,
  ExamenNota,
} from "../../../../../lib/types";

const docente = Astro.locals.docente;
const { bimestreId, gradoId, seccionId } = Astro.params;
if (!bimestreId || !gradoId || !seccionId) return Astro.redirect("/");

const [bimestre] = await query<Bimestre>`
  SELECT id, nombre, anio FROM bimestre
  WHERE id = ${bimestreId} AND docente_id = ${docente.id}
`;
if (!bimestre) return Astro.redirect("/");

const [grado] = await query<Grado>`
  SELECT g.id, g.nombre FROM grado g
  JOIN docente_grado dg ON dg.grado_id = g.id
  WHERE g.id = ${gradoId} AND dg.docente_id = ${docente.id} AND g.estado = 1
`;
if (!grado) return Astro.redirect(`/app/${bimestreId}`);

const [seccion] = await query<Seccion>`
  SELECT id, nombre FROM seccion
  WHERE id = ${seccionId} AND grado_id = ${gradoId} AND estado = 1
`;
if (!seccion) return Astro.redirect(`/app/${bimestreId}/${gradoId}`);

const [alumnos, sesiones, evaluaciones, consolidados, faltas, examenNotas] =
  await Promise.all([
    query<Alumno>`
      SELECT id, orden, nombre, apellido
      FROM alumno
      WHERE seccion_id = ${seccionId} AND estado = 1
      ORDER BY orden ASC, apellido ASC
    `,
    query<Sesion & { criterios: SesionCriterio[] }>`
      SELECT
        s.id, s.titulo,
        TO_CHAR(s.fecha, 'YYYY-MM-DD') AS fecha,
        COALESCE(
          json_agg(
            json_build_object(
              'id',            sc.id,
              'competenciaId', sc.competencia_id,
              'capacidadId',   sc.capacidad_id,
              'criterio',      sc.criterio,
              'orden',         sc.orden
            ) ORDER BY sc.orden
          ) FILTER (WHERE sc.id IS NOT NULL),
          '[]'
        ) AS criterios
      FROM sesion s
      LEFT JOIN sesion_criterio sc ON sc.sesion_id = s.id
      WHERE s.bimestre_id = ${bimestreId}
        AND s.grado_id    = ${gradoId}
        AND s.estado      = 1
      GROUP BY s.id
      ORDER BY s.fecha ASC
    `,
    query<{
      sesionCriterioId: number;
      sesionId: number;
      alumnoId: number;
      nota: string;
      observacion: string | null;
    }>`
      SELECT
        e.sesion_criterio_id AS "sesionCriterioId",
        sc.sesion_id         AS "sesionId",
        e.alumno_id          AS "alumnoId",
        e.nota,
        e.observacion
      FROM evaluacion e
      JOIN sesion_criterio sc ON e.sesion_criterio_id = sc.id
      JOIN sesion s           ON sc.sesion_id = s.id
      JOIN alumno a           ON e.alumno_id  = a.id
      WHERE s.bimestre_id  = ${bimestreId}
        AND s.grado_id     = ${gradoId}
        AND a.seccion_id   = ${seccionId}
    `,
    query<{ alumnoId: number; notaFinal: string }>`
      SELECT co.alumno_id AS "alumnoId", co.nota_final AS "notaFinal"
      FROM consolidado co
      JOIN alumno a ON co.alumno_id = a.id
      WHERE co.bimestre_id = ${bimestreId}
        AND a.seccion_id   = ${seccionId}
    `,
    query<{ sesionId: number; alumnoId: number; observacion: string | null }>`
      SELECT
        as2.sesion_id  AS "sesionId",
        as2.alumno_id  AS "alumnoId",
        as2.observacion
      FROM asistencia as2
      JOIN alumno a  ON as2.alumno_id  = a.id
      JOIN sesion s  ON as2.sesion_id  = s.id
      WHERE a.seccion_id   = ${seccionId}
        AND s.bimestre_id  = ${bimestreId}
        AND s.grado_id     = ${gradoId}
        AND as2.estado     = 'F'
    `,
    // NUEVO: notas del examen diagnóstico para alumnos de esta sección
    query<{ alumnoId: number; competenciaId: string; nota: string | null }>`
      SELECT
        en.alumno_id      AS "alumnoId",
        en.competencia_id AS "competenciaId",
        en.nota
      FROM examen_nota en
      JOIN examen_bimestre eb ON eb.id = en.examen_bimestre_id
      JOIN alumno a           ON a.id  = en.alumno_id
      WHERE eb.bimestre_id = ${bimestreId}
        AND a.seccion_id   = ${seccionId}
        AND en.nota IS NOT NULL
    `,
  ]);

const curriculo = docente.cursoNombre
  ? getCurriculoPorNombre(docente.cursoNombre)
  : null;
---

<Layout title={`Consolidado — Sección ${seccion.nombre}`}>
  <div class="mb-6">
    <nav class="flex items-center gap-1.5 text-xs text-gray-400 mb-3 flex-wrap">
      <a href={`/app/${bimestreId}`} class="hover:text-gray-600 transition-colors">
        {bimestre.nombre} {bimestre.anio}
      </a>
      <span>›</span>
      <a href={`/app/${bimestreId}/${gradoId}`} class="hover:text-gray-600 transition-colors">
        {grado.nombre}
      </a>
      <span>›</span>
      <span class="text-gray-600">Sección {seccion.nombre} — Consolidado</span>
    </nav>
    <h1 class="text-xl font-semibold text-gray-900">
      Consolidado · Sección {seccion.nombre}
    </h1>
    <p class="text-sm text-gray-400 mt-0.5">
      {grado.nombre} · {bimestre.nombre} · {bimestre.anio}
    </p>
  </div>

  <ConsolidadoTabs
    client:only="svelte"
    {alumnos}
    {sesiones}
    {evaluaciones}
    consolidadosIniciales={consolidados}
    {faltas}
    {curriculo}
    {examenNotas}
    bimestreId={Number(bimestreId)}
    seccionId={Number(seccionId)}
    seccionNombre={seccion.nombre}
    gradoNombre={grado.nombre}
    bimestreNombre={`${bimestre.nombre} ${bimestre.anio}`}
  />
</Layout>