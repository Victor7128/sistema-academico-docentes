---
import { getSession } from "auth-astro/server";

const session = await getSession(Astro.request);
if (session) return Astro.redirect("/");

const error = Astro.url.searchParams.get("error");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro Docente</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --blue: #1b3a6b; /* azul institucional profundo */
        --blue-mid: #2a5298;
        --blue-faint: #eef2f9;
        --amber: #c8882a; /* dorado cálido */
        --amber-l: #f0b955;
        --bg: #f5f3ee; /* blanco pergamino */
        --surface: #ffffff;
        --text-1: #1a2332;
        --text-2: #4a5672;
        --text-3: #8a96aa;
        --border: #dde3ee;
      }

      html,
      body {
        height: 100%;
        font-family: "DM Sans", sans-serif;
        background: var(--bg);
        color: var(--text-1);
      }

      /* ── Layout ── */
      .page {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
      }

      /* ── Panel izquierdo: azul institucional ── */
      .panel-left {
        background: var(--blue);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 4rem 5rem;
        position: relative;
        overflow: hidden;
        animation: fadeLeft 0.65s ease both;
      }

      /* Líneas de cuaderno sutiles — guiño pedagógico */
      .panel-left::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 47px,
          rgba(255, 255, 255, 0.05) 47px,
          rgba(255, 255, 255, 0.05) 48px
        );
        pointer-events: none;
      }

      /* Resplandor ámbar suave en esquina */
      .panel-left::after {
        content: "";
        position: absolute;
        top: -15%;
        right: -15%;
        width: 55%;
        height: 55%;
        background: radial-gradient(
          circle,
          rgba(200, 136, 42, 0.18) 0%,
          transparent 70%
        );
        pointer-events: none;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--amber-l);
        border: 1px solid rgba(240, 185, 85, 0.28);
        border-radius: 2rem;
        padding: 0.35rem 0.9rem;
        width: fit-content;
        margin-bottom: 2.5rem;
        position: relative;
        z-index: 1;
      }

      .badge::before {
        content: "";
        display: block;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--amber-l);
      }

      .headline {
        font-family: "DM Serif Display", serif;
        font-size: clamp(2.4rem, 4vw, 3.4rem);
        line-height: 1.1;
        color: #ffffff;
        margin-bottom: 1.25rem;
        position: relative;
        z-index: 1;
      }

      .headline em {
        font-style: italic;
        color: var(--amber-l);
      }

      .subline {
        font-size: 0.9rem;
        font-weight: 300;
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.75;
        max-width: 28ch;
        position: relative;
        z-index: 1;
      }

      .rule {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 2.5rem 0;
        position: relative;
        z-index: 1;
      }
      .rule::before,
      .rule::after {
        content: "";
        flex: 1;
        height: 1px;
        background: rgba(255, 255, 255, 0.1);
      }
      .rule span {
        font-size: 0.65rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.35);
      }

      .stats {
        display: flex;
        gap: 2.5rem;
        position: relative;
        z-index: 1;
      }
      .stat-num {
        font-family: "DM Serif Display", serif;
        font-size: 1.6rem;
        color: #ffffff;
        line-height: 1;
        margin-bottom: 0.25rem;
      }
      .stat-label {
        font-size: 0.7rem;
        letter-spacing: 0.06em;
        color: rgba(255, 255, 255, 0.4);
        text-transform: uppercase;
      }

      /* ── Panel derecho: blanco, limpio ── */
      .panel-right {
        background: var(--surface);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 4rem 5rem;
        animation: fadeRight 0.65s 0.15s ease both;
        background-image: radial-gradient(
          ellipse 70% 50% at 80% 10%,
          rgba(200, 136, 42, 0.05) 0%,
          transparent 60%
        );
      }

      .card {
        width: 100%;
        max-width: 370px;
      }

      .card-icon {
        width: 52px;
        height: 52px;
        border-radius: 0.875rem;
        background: var(--blue-faint);
        border: 1px solid rgba(27, 58, 107, 0.14);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.75rem;
      }

      .card-title {
        font-family: "DM Serif Display", serif;
        font-size: 1.85rem;
        color: var(--text-1);
        margin-bottom: 0.45rem;
      }

      .card-desc {
        font-size: 0.875rem;
        font-weight: 300;
        color: var(--text-2);
        margin-bottom: 2rem;
        line-height: 1.65;
      }

      /* Error */
      .alert {
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-left: 3px solid #dc2626;
        border-radius: 0.6rem;
        padding: 0.8rem 1rem;
        font-size: 0.82rem;
        color: #b91c1c;
        margin-bottom: 1.5rem;
        line-height: 1.55;
      }

      /* Botón Google — prominente y claro */
      .btn-google {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        background: var(--blue);
        border: none;
        border-radius: 0.875rem;
        padding: 1.05rem 1.25rem;
        font-family: "DM Sans", sans-serif;
        font-size: 0.94rem;
        font-weight: 500;
        color: #ffffff;
        cursor: pointer;
        transition:
          background 0.2s,
          transform 0.15s,
          box-shadow 0.2s;
        letter-spacing: 0.01em;
        box-shadow: 0 4px 16px rgba(27, 58, 107, 0.28);
      }

      .btn-google:hover {
        background: var(--blue-mid);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(27, 58, 107, 0.3);
      }

      .btn-google:active {
        transform: translateY(0);
        box-shadow: 0 2px 8px rgba(27, 58, 107, 0.2);
      }

      /* Logo Google sobre fondo azul: fondo blanco circular */
      .btn-google .google-icon {
        background: #ffffff;
        border-radius: 50%;
        width: 26px;
        height: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .card-divider {
        height: 1px;
        background: var(--border);
        margin: 1.75rem 0;
      }

      .card-footer {
        font-size: 0.73rem;
        color: var(--text-3);
        text-align: center;
        line-height: 1.65;
      }

      .ornament {
        position: fixed;
        bottom: 1.5rem;
        left: 50%;
        transform: translateX(-50%);
        font-family: "DM Serif Display", serif;
        font-style: italic;
        font-size: 0.72rem;
        color: rgba(138, 150, 168, 0.45);
        letter-spacing: 0.04em;
        z-index: 1;
        white-space: nowrap;
        pointer-events: none;
      }

      /* ── Animaciones ── */
      @keyframes fadeLeft {
        from {
          opacity: 0;
          transform: translateX(-20px);
        }
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }
      @keyframes fadeRight {
        from {
          opacity: 0;
          transform: translateY(14px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* ── Responsivo ── */
      @media (max-width: 768px) {
        html,
        body {
          height: auto;
        }

        .page {
          grid-template-columns: 1fr;
          min-height: 100svh;
        }

        /* Panel izquierdo: encabezado compacto visible en móvil */
        .panel-left {
          padding: 2.25rem 1.5rem 2rem;
          animation: none;
        }

        .panel-left::after {
          display: none;
        }

        .badge {
          margin-bottom: 1rem;
        }

        .headline {
          font-size: clamp(1.75rem, 7vw, 2.2rem);
          margin-bottom: 0.6rem;
        }

        .subline {
          font-size: 0.84rem;
          max-width: none;
        }

        /* Ocultar en móvil lo que no es esencial */
        .rule,
        .stats {
          display: none;
        }

        /* Panel derecho: formulario sin padding excesivo */
        .panel-right {
          padding: 2rem 1.5rem 3rem;
          align-items: stretch;
          background-image: none;
          animation: none;
        }

        .card {
          max-width: none;
        }

        .card-icon {
          margin-bottom: 1.25rem;
        }

        .card-title {
          font-size: 1.6rem;
        }

        /* Botón más grande para dedos */
        .btn-google {
          padding: 1.15rem 1.25rem;
          font-size: 1rem;
          border-radius: 1rem;
        }

        .ornament {
          display: none;
        }
      }

      @media (max-width: 400px) {
        .panel-left {
          padding: 1.75rem 1.25rem 1.75rem;
        }
        .panel-right {
          padding: 1.75rem 1.25rem 2.5rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <!-- ── Panel izquierdo: identidad ── -->
      <div class="panel-left">
        <div class="badge">Sistema académico</div>

        <h1 class="headline">
          Registro<br />
          <em>Docente</em>
        </h1>
        <p class="subline">
          Plataforma de gestión de sesiones, evaluaciones y consolidados de
          calificaciones.
        </p>

        <div class="rule"><span>Diseñado para docentes</span></div>

        <div class="stats">
          <div>
            <div class="stat-num">4</div>
            <div class="stat-label">Bimestres</div>
          </div>
          <div>
            <div class="stat-num">AD·A·B·C</div>
            <div class="stat-label">Sistema de notas</div>
          </div>
          <div>
            <div class="stat-num">100%</div>
            <div class="stat-label">En línea</div>
          </div>
        </div>
      </div>

      <!-- ── Panel derecho: login ── -->
      <div class="panel-right">
        <div class="card">
          <!-- Ícono -->
          <div class="card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <path
                d="M12 2L2 7l10 5 10-5-10-5z"
                stroke="#c9a84c"
                stroke-width="1.5"
                stroke-linejoin="round"></path>
              <path
                d="M2 17l10 5 10-5"
                stroke="#c9a84c"
                stroke-width="1.5"
                stroke-linejoin="round"></path>
              <path
                d="M2 12l10 5 10-5"
                stroke="#c9a84c"
                stroke-width="1.5"
                stroke-linejoin="round"></path>
            </svg>
          </div>

          <h2 class="card-title">Bienvenido</h2>
          <p class="card-desc">
            Accede con tu cuenta institucional de Google para continuar.
          </p>

          {
            error === "no_autorizado" && (
              <div class="alert">
                Tu cuenta no está autorizada en este sistema. Contacta al
                administrador.
              </div>
            )
          }

          <button id="btn-google" class="btn-google">
            <!-- Google icon envuelto en círculo blanco para visibilidad sobre azul -->
            <span class="google-icon">
              <svg width="16" height="16" viewBox="0 0 18 18">
                <path
                  fill="#4285F4"
                  d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"
                ></path>
                <path
                  fill="#34A853"
                  d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332C2.438 15.983 5.482 18 9 18z"
                ></path>
                <path
                  fill="#FBBC05"
                  d="M3.964 10.707c-.18-.54-.282-1.117-.282-1.707s.102-1.167.282-1.707V4.961H.957C.347 6.175 0 7.55 0 9s.348 2.825.957 4.039l3.007-2.332z"
                ></path>
                <path
                  fill="#EA4335"
                  d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.482 0 2.438 2.017.957 4.961L3.964 7.293C4.672 5.166 6.656 3.58 9 3.58z"
                ></path>
              </svg>
            </span>
            Continuar con Google
          </button>

          <div class="card-divider"></div>

          <p class="card-footer">
            Acceso restringido a docentes autorizados.<br />
            Solo cuentas Google verificadas.
          </p>
        </div>
      </div>
    </div>

    <div class="ornament">Sistema de Registro Académico Docente</div>

    <script>
      import { signIn } from "auth-astro/client";
      document.getElementById("btn-google")!.onclick = () => signIn("google");
    </script>
  </body>
</html>
