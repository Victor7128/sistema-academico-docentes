---
interface Props {
  href: string;
  titulo: string;
  subtitulo?: string;
  meta?: string;
}

const { href, titulo, subtitulo, meta } = Astro.props;
---

<a href={href} class="nav-card">
  <div class="nav-card__body">
    <span class="nav-card__title">{titulo}</span>
    {subtitulo && <span class="nav-card__sub">{subtitulo}</span>}
  </div>

  <div class="nav-card__right">
    {meta && <span class="nav-card__meta">{meta}</span>}
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="nav-card__arrow">
      <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5"
            stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</a>

<style>
  .nav-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #ffffff;
    border: 1px solid #DDE3EE;
    border-radius: .875rem;
    padding: .9rem 1.1rem;
    text-decoration: none;
    transition: border-color .18s, box-shadow .18s, transform .15s;
    border-left: 3px solid transparent;
  }
  .nav-card:hover {
    border-color: rgba(27,58,107,.28);
    border-left-color: #1B3A6B;
    box-shadow: 0 3px 12px rgba(27,58,107,.08);
    transform: translateX(2px);
  }
  .nav-card__body { display: flex; flex-direction: column; gap: .2rem; }
  .nav-card__title { font-size: .88rem; font-weight: 500; color: #1A2332; transition: color .15s; }
  .nav-card:hover .nav-card__title { color: #1B3A6B; }
  .nav-card__sub { font-size: .75rem; color: #8A96AA; }
  .nav-card__right { display: flex; align-items: center; gap: .75rem; }
  .nav-card__meta {
    font-size: .72rem; color: #8A96AA;
    background: #F5F3EE; border: 1px solid #DDE3EE;
    border-radius: 999px; padding: .18rem .65rem; white-space: nowrap;
  }
  .nav-card__arrow { color: #C8D3E8; transition: color .15s, transform .15s; }
  .nav-card:hover .nav-card__arrow { color: #1B3A6B; transform: translateX(2px); }
</style>