---
import Layout from '../../../../layouts/Layout.astro';
import SeccionCRUD from '../../../../components/svelte/SeccionCRUD.svelte';
import { query } from '../../../../lib/db';
import type { Bimestre, Grado, Seccion } from '../../../../lib/types';

const docente = Astro.locals.docente;
const { bimestreId, gradoId } = Astro.params;
if (!bimestreId || !gradoId) return Astro.redirect('/');

const [bimestre] = await query<Bimestre>`
  SELECT id, nombre, anio FROM bimestre
  WHERE id = ${bimestreId} AND docente_id = ${docente.id}
`;
if (!bimestre) return Astro.redirect('/');

const [grado] = await query<Grado>`
  SELECT g.id, g.nombre FROM grado g
  JOIN docente_grado dg ON dg.grado_id = g.id
  WHERE g.id = ${gradoId} AND dg.docente_id = ${docente.id} AND g.estado = 1
`;
if (!grado) return Astro.redirect(`/app/${bimestreId}`);

const secciones = await query<Seccion & { totalAlumnos: number }>`
  SELECT
    s.id, s.nombre, s.estado,
    COUNT(a.id) FILTER (WHERE a.estado = 1) AS "totalAlumnos"
  FROM seccion s
  LEFT JOIN alumno a ON a.seccion_id = s.id
  WHERE s.grado_id = ${gradoId}
  GROUP BY s.id, s.nombre, s.estado
  ORDER BY s.nombre
`;
---

<Layout title={`${grado.nombre} — ${bimestre.nombre}`}>

  <div class="mb-6">
    <h1 class="text-xl font-semibold text-gray-900">{grado.nombre}</h1>
    <p class="text-sm text-gray-400 mt-0.5">{bimestre.nombre} · {bimestre.anio}</p>
  </div>

  <SeccionCRUD
    client:load
    secciones={secciones}
    gradoId={Number(gradoId)}
    bimestreId={Number(bimestreId)}
  />

</Layout>