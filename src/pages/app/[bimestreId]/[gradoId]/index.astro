---
import Layout from '../../../../layouts/Layout.astro';
import SeccionCRUD from '../../../../components/svelte/SeccionCRUD.svelte';
import { query } from '../../../../lib/db';
import type { Bimestre, Grado, Seccion } from '../../../../lib/types';

const docente = Astro.locals.docente;
const { bimestreId, gradoId } = Astro.params;
if (!bimestreId || !gradoId) return Astro.redirect('/');

// ── 3 queries → 1: verifica acceso a bimestre+grado en un solo JOIN ───────
const [acceso] = await query<{ bNombre: string; bAnio: number; gNombre: string }>`
  SELECT
    b.nombre  AS "bNombre",
    b.anio    AS "bAnio",
    g.nombre  AS "gNombre"
  FROM bimestre b
  JOIN docente_grado dg ON dg.docente_id = ${docente.id}
  JOIN grado g ON g.id = dg.grado_id
  WHERE b.id          = ${bimestreId}
    AND b.docente_id  = ${docente.id}
    AND g.id          = ${gradoId}
    AND g.estado      = 1
`;
if (!acceso) return Astro.redirect('/');

// Secciones: query independiente (necesita gradoId verificado)
const secciones = await query<Seccion & { totalAlumnos: number }>`
  SELECT
    s.id, s.nombre, s.estado,
    COUNT(a.id) FILTER (WHERE a.estado = 1) AS "totalAlumnos"
  FROM seccion s
  LEFT JOIN alumno a ON a.seccion_id = s.id
  WHERE s.grado_id = ${gradoId}
  GROUP BY s.id, s.nombre, s.estado
  ORDER BY s.nombre
`;
---

<Layout title={`${acceso.gNombre} — ${acceso.bNombre}`}>

  <div class="mb-6">
    <h1 class="text-xl font-semibold text-gray-900">{acceso.gNombre}</h1>
    <p class="text-sm text-gray-400 mt-0.5">{acceso.bNombre} · {acceso.bAnio}</p>
  </div>

  <SeccionCRUD
    client:load
    secciones={secciones}
    gradoId={Number(gradoId)}
    bimestreId={Number(bimestreId)}
  />

</Layout>