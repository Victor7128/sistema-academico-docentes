---
const pathname = Astro.url.pathname;
const segments = pathname.split('/').filter(Boolean);

const tieneIds = segments.some(s => /^\d+$/.test(s));
if (tieneIds) return;

interface Crumb { label: string; href: string; }

const LABELS: Record<string, string> = {
  app: '',
  alumnos: 'Alumnos',
  sesiones: 'Sesiones',
  consolidado: 'Consolidado',
};

const crumbs: Crumb[] = [{ label: 'Inicio', href: '/' }];

let path = '';
for (const seg of segments) {
  if (seg === 'app') continue;
  path += `/${seg}`;
  const label = LABELS[seg] ?? seg;
  crumbs.push({ href: path, label });
}
---

{crumbs.length > 1 && (
  <nav class="bc">
    {crumbs.map((crumb, i) => (
      <span class="bc__item">
        {i > 0 && <span class="bc__sep">›</span>}
        {i === crumbs.length - 1
          ? <span class="bc__current">{crumb.label}</span>
          : <a href={crumb.href} class="bc__link">{crumb.label}</a>
        }
      </span>
    ))}
  </nav>
)}

<style>
  .bc { display: flex; align-items: center; flex-wrap: wrap; gap: .25rem; font-size: .73rem; }
  .bc__item { display: flex; align-items: center; gap: .25rem; }
  .bc__sep { color: #C8D3E8; user-select: none; }
  .bc__link { color: #8A96AA; text-decoration: none; transition: color .15s; }
  .bc__link:hover { color: #1B3A6B; }
  .bc__current { color: #4A5672; font-weight: 500; }
</style>