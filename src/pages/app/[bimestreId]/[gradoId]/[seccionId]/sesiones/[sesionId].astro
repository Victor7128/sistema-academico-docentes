---
import Layout from '../../../../../../layouts/Layout.astro';
import EvaluacionForm from '../../../../../../components/svelte/EvaluacionForm.svelte';
import { query } from '../../../../../../lib/db';
import { getCurriculoPorNombre } from '../../../../../../lib/curriculo/index';
import type { Sesion, SesionCriterio, Alumno, Evaluacion } from '../../../../../../lib/types';

const docente = Astro.locals.docente;
const { bimestreId, gradoId, seccionId, sesionId } = Astro.params;
if (!bimestreId || !gradoId || !seccionId || !sesionId) return Astro.redirect('/');

// ── 7 queries → 3: acceso en 1 JOIN, luego 2 en paralelo ─────────────────

// 1. Verificar acceso completo + obtener nombres en un solo JOIN
const [acceso] = await query<{
  bNombre: string; bAnio: number;
  gNombre: string;
  sNombre: string;
}>`
  SELECT
    b.nombre  AS "bNombre",
    b.anio    AS "bAnio",
    g.nombre  AS "gNombre",
    s.nombre  AS "sNombre"
  FROM bimestre b
  JOIN docente_grado dg ON dg.docente_id = ${docente.id}
  JOIN grado g   ON g.id   = dg.grado_id
  JOIN seccion s ON s.grado_id = g.id
  WHERE b.id         = ${bimestreId}
    AND b.docente_id = ${docente.id}
    AND g.id         = ${gradoId}
    AND g.estado     = 1
    AND s.id         = ${seccionId}
    AND s.estado     = 1
`;
if (!acceso) return Astro.redirect('/');

// 2. Sesión + alumnos + evaluaciones + curso: todo en paralelo
const [sesionResult, alumnos, evaluaciones] = await Promise.all([
  query<Sesion & { criterios: SesionCriterio[] }>`
    SELECT
      s.id, s.titulo, s.producto, s.fecha, s.estado,
      COALESCE(
        json_agg(
          json_build_object(
            'id',            sc.id,
            'competenciaId', sc.competencia_id,
            'capacidadId',   sc.capacidad_id,
            'criterio',      sc.criterio,
            'orden',         sc.orden
          ) ORDER BY sc.orden
        ) FILTER (WHERE sc.id IS NOT NULL),
        '[]'
      ) AS criterios
    FROM sesion s
    LEFT JOIN sesion_criterio sc ON sc.sesion_id = s.id
    WHERE s.id          = ${sesionId}
      AND s.bimestre_id = ${bimestreId}
      AND s.grado_id    = ${gradoId}
    GROUP BY s.id
  `,
  query<Alumno>`
    SELECT id, nombre, apellido, orden
    FROM alumno
    WHERE seccion_id = ${seccionId} AND estado = 1
    ORDER BY orden ASC, apellido ASC, nombre ASC
  `,
  query<Evaluacion>`
    SELECT
      e.id,
      e.sesion_criterio_id AS "sesionCriterioId",
      e.alumno_id          AS "alumnoId",
      e.nota,
      e.observacion
    FROM evaluacion e
    JOIN sesion_criterio sc ON e.sesion_criterio_id = sc.id
    WHERE sc.sesion_id = ${sesionId}
  `,
]);

const [sesion] = sesionResult;
if (!sesion || sesion.estado === 0)
  return Astro.redirect(`/app/${bimestreId}/${gradoId}/${seccionId}/sesiones`);

// Currículo: local, sin query adicional
const curriculo = getCurriculoPorNombre(
  docente.cursoNombre ?? ''
) ?? null;
---

<Layout title={`Evaluación — ${sesion.titulo}`}>
  <style>
    .ph { font-family: 'DM Serif Display', serif; font-size: clamp(1.3rem, 3vw, 1.65rem); color: #1A2332; line-height: 1.2; }
    .pm { font-size: .78rem; color: #8A96AA; margin-top: .2rem; }
    .pbc { display: flex; align-items: center; gap: .3rem; font-size: .72rem; flex-wrap: wrap; margin-bottom: .6rem; }
    .pbc a { color: #8A96AA; text-decoration: none; transition: color .15s; }
    .pbc a:hover { color: #1B3A6B; }
    .pbc-sep { color: #C8D3E8; }
    .pbc-cur { color: #4A5672; font-weight: 500; }
  </style>

  <div style="margin-bottom:1.5rem;">
    <nav class="pbc">
      <a href={`/app/${bimestreId}`}>{acceso.bNombre} {acceso.bAnio}</a>
      <span class="pbc-sep">›</span>
      <a href={`/app/${bimestreId}/${gradoId}`}>{acceso.gNombre}</a>
      <span class="pbc-sep">›</span>
      <a href={`/app/${bimestreId}/${gradoId}/${seccionId}/sesiones`}>Sección {acceso.sNombre}</a>
      <span class="pbc-sep">›</span>
      <span class="pbc-cur">Evaluación</span>
    </nav>
    <h1 class="ph">{sesion.titulo}</h1>
    <p class="pm">
      {new Date(sesion.fecha + 'T12:00:00').toLocaleDateString('es-PE', {
        weekday: 'long', day: '2-digit', month: 'long', year: 'numeric',
      })}
      {sesion.producto ? `· ${sesion.producto}` : ''}
    </p>
  </div>

  <EvaluacionForm
    client:load
    sesion={sesion}
    alumnos={alumnos}
    evaluacionesIniciales={evaluaciones}
    curriculo={curriculo}
    sesionId={Number(sesionId)}
  />
</Layout>