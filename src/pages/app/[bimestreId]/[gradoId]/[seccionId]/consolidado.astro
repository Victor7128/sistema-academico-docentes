---
import Layout from '../../../../../layouts/Layout.astro';
import ConsolidadoForm from '../../../../../components/svelte/Consolidado.svelte';
import { query } from '../../../../../lib/db';
import { getCurriculoPorNombre } from '../../../../../lib/curriculo/index';
import type { Bimestre, Grado, Seccion, Alumno, Sesion, SesionCriterio } from '../../../../../lib/types';

const docente = Astro.locals.docente;
const { bimestreId, gradoId, seccionId } = Astro.params;
if (!bimestreId || !gradoId || !seccionId) return Astro.redirect('/');

const [bimestre] = await query<Bimestre>`
  SELECT id, nombre, anio FROM bimestre
  WHERE id = ${bimestreId} AND docente_id = ${docente.id}
`;
if (!bimestre) return Astro.redirect('/');

const [grado] = await query<Grado>`
  SELECT g.id, g.nombre FROM grado g
  JOIN docente_grado dg ON dg.grado_id = g.id
  WHERE g.id = ${gradoId} AND dg.docente_id = ${docente.id} AND g.estado = 1
`;
if (!grado) return Astro.redirect(`/app/${bimestreId}`);

const [seccion] = await query<Seccion>`
  SELECT id, nombre FROM seccion
  WHERE id = ${seccionId} AND grado_id = ${gradoId} AND estado = 1
`;
if (!seccion) return Astro.redirect(`/app/${bimestreId}/${gradoId}`);

// Alumnos activos
const alumnos = await query<Alumno>`
  SELECT id, orden, nombre, apellido
  FROM alumno
  WHERE seccion_id = ${seccionId} AND estado = 1
  ORDER BY orden ASC, apellido ASC
`;

// Sesiones activas del bimestre con sus criterios
const sesiones = await query<Sesion & { criterios: SesionCriterio[] }>`
  SELECT
    s.id, s.titulo, s.fecha,
    COALESCE(
      json_agg(
        json_build_object(
          'id',            sc.id,
          'competenciaId', sc.competencia_id,
          'capacidadId',   sc.capacidad_id,
          'criterio',      sc.criterio,
          'orden',         sc.orden
        ) ORDER BY sc.orden
      ) FILTER (WHERE sc.id IS NOT NULL),
      '[]'
    ) AS criterios
  FROM sesion s
  LEFT JOIN sesion_criterio sc ON sc.sesion_id = s.id
  WHERE s.bimestre_id = ${bimestreId}
    AND s.grado_id    = ${gradoId}
    AND s.estado      = 1
  GROUP BY s.id
  ORDER BY s.fecha ASC
`;

// Evaluaciones de los alumnos de esta sección en este bimestre
const evaluaciones = await query<{
  sesionCriterioId: number;
  sesionId: number;
  alumnoId: number;
  nota: string;
}>`
  SELECT
    e.sesion_criterio_id AS "sesionCriterioId",
    sc.sesion_id         AS "sesionId",
    e.alumno_id          AS "alumnoId",
    e.nota
  FROM evaluacion e
  JOIN sesion_criterio sc ON e.sesion_criterio_id = sc.id
  JOIN sesion s           ON sc.sesion_id = s.id
  JOIN alumno a           ON e.alumno_id  = a.id
  WHERE s.bimestre_id  = ${bimestreId}
    AND s.grado_id     = ${gradoId}
    AND a.seccion_id   = ${seccionId}
`;

// Consolidados ya calculados
const consolidados = await query<{ alumnoId: number; notaFinal: string }>`
  SELECT co.alumno_id AS "alumnoId", co.nota_final AS "notaFinal"
  FROM consolidado co
  JOIN alumno a ON co.alumno_id = a.id
  WHERE co.bimestre_id = ${bimestreId}
    AND a.seccion_id   = ${seccionId}
`;

const [cursoDocente] = await query<{ nombre: string }>`
  SELECT nombre FROM curso WHERE id = ${docente.cursoId}
`;
const curriculo = cursoDocente ? getCurriculoPorNombre(cursoDocente.nombre) : null;
---

<Layout title={`Consolidado — Sección ${seccion.nombre}`}>
  <style>
    .ph { font-family: 'DM Serif Display', serif; font-size: clamp(1.35rem, 3vw, 1.7rem); color: #1A2332; line-height: 1.15; }
    .pm { font-size: .78rem; color: #8A96AA; margin-top: .2rem; }
    .pbc { display: flex; align-items: center; gap: .3rem; font-size: .72rem; flex-wrap: wrap; margin-bottom: .6rem; }
    .pbc a { color: #8A96AA; text-decoration: none; transition: color .15s; }
    .pbc a:hover { color: #1B3A6B; }
    .pbc-sep { color: #C8D3E8; }
    .pbc-cur { color: #4A5672; font-weight: 500; }
  </style>

  <div style="margin-bottom:1.5rem;">
    <nav class="pbc">
      <a href={`/app/${bimestreId}`}>{bimestre.nombre} {bimestre.anio}</a>
      <span class="pbc-sep">›</span>
      <a href={`/app/${bimestreId}/${gradoId}`}>{grado.nombre}</a>
      <span class="pbc-sep">›</span>
      <a href={`/app/${bimestreId}/${gradoId}/${seccionId}`}>Sección {seccion.nombre}</a>
      <span class="pbc-sep">›</span>
      <span class="pbc-cur">Consolidado</span>
    </nav>
    <h1 class="ph">Consolidado <span style="font-style:italic;color:#C8882A;">· Sección {seccion.nombre}</span></h1>
    <p class="pm">{grado.nombre} · {bimestre.nombre} {bimestre.anio}</p>
  </div>

  <ConsolidadoForm
    client:load
    alumnos={alumnos}
    sesiones={sesiones}
    evaluaciones={evaluaciones}
    consolidadosIniciales={consolidados}
    curriculo={curriculo}
    bimestreId={Number(bimestreId)}
    seccionId={Number(seccionId)}
    seccionNombre={seccion.nombre}
    gradoNombre={grado.nombre}
    bimestreNombre={`${bimestre.nombre} ${bimestre.anio}`}
  />
</Layout>